\ ============================================================
\ Regime classification (per PREDICTIONS-131.md threshold rule,
\ NOT per the inverted prose labels).
\ ============================================================

\ Regime O: R_max ∈ [1.5, 2.0]. R=1.500 EXACTLY at boundary,
\ inclusive.  Check 1.5 ≤ R_max ≤ 2.0 via ×1000 form.
"max-R-1000x" load 1500 >= "max-R-1000x" load 2000 <= * "regime-O?" store

\ Regime N: R_max > 2.0.
"max-R-1000x" load 2000 > "regime-N?" store

\ Regime P: R_max ∈ [1.0, 1.5).
"max-R-1000x" load 1000 >= "max-R-1000x" load 1500 < * "regime-P?" store

\ Regime Q: R_max < 1.0.
"max-R-1000x" load 1000 < "regime-Q?" store

\ Partition check.
"regime-N?" load "regime-O?" load + "regime-P?" load + "regime-Q?" load +
   "regime-count" store

\ ============================================================
\ Mean R DECREASES with n (substrate-derived trend).
\ ============================================================

\ Monotone: mean_R(n=3) > mean_R(n=4) > mean_R(n=5) > mean_R(n=6).
"mean-R-n3-1000x" load "mean-R-n4-1000x" load > "mono34?" store
"mean-R-n4-1000x" load "mean-R-n5-1000x" load > "mono45?" store
"mean-R-n5-1000x" load "mean-R-n6-1000x" load > "mono56?" store

"mono34?" load "mono45?" load * "mono56?" load * "monotone-decrease?" store

