\ induction is the architecturally different next test.

use prelude
use debug

\ Pinned aggregates (pred_wins for each alpha).
2   "pw-alpha-001" store
0   "pw-alpha-01"  store
0   "pw-alpha-1"   store

\ Best alpha = 0.01.
2   "best-pred-wins" store

\ Concentration flag (winners subset of {path, ER_n10}).
1   "concentrated"  store

\ delta_spread across alphas (positive non-trivial = landscape has structure).
\ Stored as integer x10000: 0.00635 -> 63.
63  "delta-spread-x10k" store

\ Regime classifier.
"best-pred-wins" load 4 >= "aaaaa-pass?" store
"best-pred-wins" load 3 >= "bbbbb-weak-pass?" store
"best-pred-wins" load 2 <= "ccccc-fail-by-wins?" store
"concentrated"   load 1 = "ccccc-fail-by-conc?" store

\ CCCCC fires if EITHER condition is met.
"ccccc-fail-by-wins?" load "ccccc-fail-by-conc?" load + 0 > "regime-CCCCC?" store

cr
"=== Demo 142 — STEP-CA-PRED (cycle 23 Phase A) ===" . cr
cr
"L23 = PredError + alpha*(K/n) + gamma*DegeneracyPenalty" . cr
"  gamma=0.1, alpha grid {0.01, 0.1, 1} pre-committed" . cr
"  PASS evaluated by PredError vs degree baseline" . cr
cr
"Per-alpha pred_wins (out of 6 substrates):" . cr
"  alpha=0.01:  " . "pw-alpha-001" load . "  (mean_delta +0.00082, CONCENTRATED)" . cr
"  alpha=0.1 :  " . "pw-alpha-01"  load . "  (mean_delta -0.00189)" . cr
"  alpha=1.0 :  " . "pw-alpha-1"   load . "  (mean_delta -0.00553)" . cr
cr
"delta_spread across alphas (x10000): " . "delta-spread-x10k" load . cr
"  -> non-trivial landscape structure, search-limited" . cr
cr
"AAAAA  (>=4 wins, robust):  " . "aaaaa-pass?"     load . cr
"BBBBB  (>=3 wins):          " . "bbbbb-weak-pass?" load . cr
"CCCCC  (<=2 OR concentrated):" . "regime-CCCCC?"  load . cr
cr

"regime-CCCCC?" load 1 = if
  ">>> REGIME CCCCC — Predictive-only ALSO fails on NSUM benchmark." . cr
  "    Three loss families (MDL, MDL+Pred, Pred-only) all <=2/6." . cr
  "    delta_spread non-trivial -> landscape has structure," . cr
  "    BUT search cannot beat degree because degree IS the oracle" . cr
  "    for a_{t+1} = normalize(A*a_t) dynamics." . cr
  "    Loss-family hypothesis on NSUM benchmark: EXHAUSTED." . cr
  "    Pivot (cycle 24+): runtime primitive induction." . cr
then

\ Sanity asserts.
"regime-CCCCC?"     load 1 assert-eq
"best-pred-wins"    load 2 assert-eq
"concentrated"      load 1 assert-eq
"aaaaa-pass?"       load 0 assert-eq
"bbbbb-weak-pass?"  load 0 assert-eq
"pw-alpha-001"      load 2 assert-eq

