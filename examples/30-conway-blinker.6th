EDGES 144 assert-eq

: clear-all
  1 0 NSET   2 0 NSET   3 0 NSET   4 0 NSET   5 0 NSET
  6 0 NSET   7 0 NSET   8 0 NSET   9 0 NSET  10 0 NSET
  11 0 NSET  12 0 NSET  13 0 NSET  14 0 NSET  15 0 NSET
  16 0 NSET  17 0 NSET  18 0 NSET  19 0 NSET  20 0 NSET
  21 0 NSET  22 0 NSET  23 0 NSET  24 0 NSET  25 0 NSET ;

clear-all
8 1 NSET    13 1 NSET    18 1 NSET

8 NGET 1 assert-eq
13 NGET 1 assert-eq
18 NGET 1 assert-eq
9 NGET 0 assert-eq
12 NGET 0 assert-eq

13 NSUM 2 assert-eq
12 NSUM 3 assert-eq
14 NSUM 3 assert-eq

\ Step 1: vertical → horizontal.
' conway STEP-CA
8 NGET 0 assert-eq
18 NGET 0 assert-eq
13 NGET 1 assert-eq
12 NGET 1 assert-eq
14 NGET 1 assert-eq

\ Step 2: back to vertical.
' conway STEP-CA
12 NGET 0 assert-eq
14 NGET 0 assert-eq
13 NGET 1 assert-eq
8 NGET 1 assert-eq
18 NGET 1 assert-eq

\ Step 3: horizontal (period 2 confirmed).
' conway STEP-CA
12 NGET 1 assert-eq
14 NGET 1 assert-eq
13 NGET 1 assert-eq
8 NGET 0 assert-eq
18 NGET 0 assert-eq

