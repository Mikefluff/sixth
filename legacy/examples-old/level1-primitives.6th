    0 > if 1 else 0 1 - then
  then ;

: sum-squares 
  dup * swap dup * + ;

: average + 2 / ;

: last-digit 10 mod ;

: even? 2 mod 0 = ;

: triple dup dup + + ;

: swap3 rot swap rot ;

: rot-back rot rot ;

