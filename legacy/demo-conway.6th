\ Total: 20 horizontal + 20 vertical + 16 NW-SE + 16 NE-SW = 72 bi-edge pairs
EDGES 144 = ASSERT

\ ─── BLINKER: three live cells in column 3 at rows 2,3,4 ───
\ Node ids: (2-1)*5+3=8,  (3-1)*5+3=13,  (4-1)*5+3=18
\ Initialise all dead, then 3 alive
: clear-all
  1 0 NSET   2 0 NSET   3 0 NSET   4 0 NSET   5 0 NSET
  6 0 NSET   7 0 NSET   8 0 NSET   9 0 NSET  10 0 NSET
  11 0 NSET  12 0 NSET  13 0 NSET  14 0 NSET  15 0 NSET
  16 0 NSET  17 0 NSET  18 0 NSET  19 0 NSET  20 0 NSET
  21 0 NSET  22 0 NSET  23 0 NSET  24 0 NSET  25 0 NSET ;

clear-all
8 1 NSET    13 1 NSET    18 1 NSET     \ vertical blinker

\ Sanity: only these 3 are alive
8 NGET 1 = ASSERT
13 NGET 1 = ASSERT
18 NGET 1 = ASSERT
9 NGET 0 = ASSERT
12 NGET 0 = ASSERT

\ Neighbours of cell 13 (centre): should sum to 2 (live: 8 and 18)
13 NSUM 2 = ASSERT
\ Neighbours of cell 12 (left of centre): 8, 13, 18 are diagonal/adjacent
\   neighbours of 12 are 6,7,8,11,13,16,17,18 → live ones are 8,13,18 = sum 3
12 NSUM 3 = ASSERT
14 NSUM 3 = ASSERT                          \ symmetric (right side)

\ ─── step 1: oscillate vertical → horizontal ───
' conway STEP-CA
\ Vertical cells (except centre) die; cells 12 and 14 are born; centre stays
8 NGET 0 = ASSERT
18 NGET 0 = ASSERT
13 NGET 1 = ASSERT
12 NGET 1 = ASSERT
14 NGET 1 = ASSERT

\ ─── step 2: oscillate back to vertical ───
' conway STEP-CA
12 NGET 0 = ASSERT
14 NGET 0 = ASSERT
13 NGET 1 = ASSERT
8 NGET 1 = ASSERT
18 NGET 1 = ASSERT

\ ─── step 3: horizontal again (period confirmed) ───
' conway STEP-CA
12 NGET 1 = ASSERT
14 NGET 1 = ASSERT
13 NGET 1 = ASSERT
8 NGET 0 = ASSERT
18 NGET 0 = ASSERT

\ ─── interpretation ───
\ Same substrate (graph + features + STEP-CA) runs Conway just as it
\ ran Rule 90, Rule 110, and the Rule 184 glider.  All it took to lift
\ the substrate from 1D to 2D dynamics was a different connectivity
\ (Moore neighbourhood) and a richer local rule.  Substrate is the
\ general medium; CA is just one usage pattern.

REPORT
